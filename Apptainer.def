Bootstrap: docker
From: ollama/ollama

%files
    # This replaces your COPY commands
    # Format: [source on host] [destination in container]
    requirements.txt /root/requirements.txt
    entrypoint.sh /root/entrypoint.sh

%post
    # This section replaces your RUN commands
    apt-get update
    apt-get install -y python3 python3-pip vim git
    
    # Install python requirements
    # Note: we use the path where the file is copied during the build
    pip3 install --break-system-packages -r /root/requirements.txt
    chmod +x /root/entrypoint.sh

%environment
    export WORKDIR=/root

%runscript
    # This replaces your ENTRYPOINT
    cd /root
    exec ./entrypoint.sh
