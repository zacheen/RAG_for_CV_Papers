# Copy this file to `.env` and fill in your real values.
# `.env` is git-ignored, `.env.example` is committed as a template.

# Google AI Studio (Gemini) API key 
# get one free at https://aistudio.google.com/apikey
# check https://ai.dev/rate-limit for API limitation
GOOGLE_API_KEY = your_google_ai_studio_api_key_here

# LLM backend: "ollama" (default, original behavior) or "gemini"
LLM_BACKEND = ollama

# Optional: override the Gemini model name
# GEMINI_MODEL=gemini-3.1-flash-lite

# Optional: override Ollama base URL
# OLLAMA_BASE_URL=http://localhost:11434
